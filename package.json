{
  "name": "@neovici/resizable",
  "version": "1.0.0",
  "description": "A simple, lightweight web component for resizing two adjacent elements with a draggable divider line",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neovici/resizable.git"
  },
  "keywords": [
    "web-components",
    "split",
    "resizer",
    "resize",
    "pane",
    "divider",
    "draggable",
    "layout",
    "shadow-dom",
    "pionjs"
  ],
  "author": "",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Neovici/resizable#readme",
  "main": "dist/index.js",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "lint": "tsc && eslint --cache .",
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run storybook:start",
    "dev": "npm run storybook:start",
    "test": "wtr --coverage && vitest --project=storybook --run",
    "test:watch": "wtr --watch",
    "test:storybook": "vitest --project=storybook --run",
    "check:duplicates": "check-duplicate-components",
    "changeset": "changeset",
    "storybook:start": "storybook dev -p 8000 -h 0.0.0.0",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook-to-ghpages",
    "storybook:preview": "npm run storybook:build && http-server ./storybook-static/ --silent",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "@pionjs/pion": "^2.16.1",
    "lit-html": "^3.3.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@neovici/cfg": "^2.11.0",
    "@neovici/testing": "^2.3.0",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-vitest": "^10.2.4",
    "@storybook/web-components-vite": "^10.2.4",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.5.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "esbuild": "^0.21.4",
    "http-server": "^14.1.1",
    "husky": "^9.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.0.0",
    "shadow-dom-testing-library": "^1.13.1",
    "sinon": "^22.0.0",
    "storybook": "^10.0.0",
    "typescript": "^5.4.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "conventional-changelog-conventionalcommits": ">= 8.0.0"
  }
}
